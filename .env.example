# Copiar a .env antes de compilar la APK release (sync requiere estas variables).
# EXPO_PUBLIC_SYNC_* = identidad TÉCNICA de sync (no el operador de campo). Ver sync-identity.ts.
EXPO_PUBLIC_AWS_REGION=
EXPO_PUBLIC_AWS_USER_POOL_ID=
EXPO_PUBLIC_AWS_USER_POOL_CLIENT_ID=
EXPO_PUBLIC_AWS_APPSYNC_ENDPOINT=
EXPO_PUBLIC_AWS_APPSYNC_API_KEY=
# Usuario Cognito con permiso de lectura maestros (idealmente cuenta de servicio, no staff personal).
EXPO_PUBLIC_SYNC_USERNAME=
EXPO_PUBLIC_SYNC_PASSWORD=
