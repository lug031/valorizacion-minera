# Copiar a .env antes de compilar la APK release.
# Piloto/producción: no use EXPO_PUBLIC_ENABLE_DEV_SEED ni credenciales demo.
# EXPO_PUBLIC_REQUIRE_DEVICE_ENROLLMENT=false solo para pruebas locales sin código de activación.
# Ejecute `npm run validate:release-env` antes del build release.
EXPO_PUBLIC_AWS_REGION=
EXPO_PUBLIC_AWS_USER_POOL_ID=
EXPO_PUBLIC_AWS_USER_POOL_CLIENT_ID=
EXPO_PUBLIC_AWS_APPSYNC_ENDPOINT=
EXPO_PUBLIC_AWS_APPSYNC_API_KEY=
# No incluir credenciales de sync en EXPO_PUBLIC_*.
EXPO_PUBLIC_REQUIRE_DEVICE_ENROLLMENT=true
# Opcional: solo desarrollo (admin/operador demo en SQLite)
# EXPO_PUBLIC_ENABLE_DEV_SEED=true
# EXPO_PUBLIC_REQUIRE_DEVICE_ENROLLMENT=false
